VITE_SUPABASE_URL=<url>
VITE_SUPABASE_ANON_KEY=<anon-key>
VITE_CLOUDFLARED_WORKER_URL=<worker_url>
VITE_GOOGLE_MAP_DEMO_KEY=<google-maps-api-key>
# Map ID enables the WebGL vector renderer — required for setTilt() 3D perspective.
# Create one free: Google Cloud Console → Google Maps Platform → Map Management → Create Map ID (type: JavaScript, renderer: Vector)
VITE_GOOGLE_MAP_VECTOR_ID=<map-id>